@model WizardConfirmVm
<h3>Шаг 3 из 3 — Подтверждение</h3>
<div class="progress mb-3"><div class="progress-bar" style="width:100%"></div></div>
<div class="card mb-3"><div class="card-body">
    <h5>@Model.TemplateName (v@Model.TemplateVersion)</h5>
    <ul>
        @foreach (var item in Model.Values)
        {
            <li>
                <b>@item.Key:</b>
                @if (!string.IsNullOrWhiteSpace(item.Value) && item.Value.StartsWith("/uploads/"))
                {
                    <div><img src="@item.Value" style="max-width:200px;max-height:120px" alt="@item.Key" /></div>
                }
                else
                {
                    @item.Value
                }
            </li>
        }
    </ul>
</div></div>
<form method="post" asp-action="Generate">
    <button class="btn btn-success btn-lg">Сгенерировать</button>
    <a class="btn btn-secondary" asp-action="Step1">Создать ещё</a>
</form>
