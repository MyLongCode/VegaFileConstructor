@model VegaFileConstructor.ViewModels.PdfEditWizardViewModel

<h2>Шаг 2 из 3. Что заменить</h2>
<div class="progress mb-3"><div class="progress-bar" style="width:66%"></div></div>

<div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

<form asp-action="Confirm" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="OperationId" />
    <input type="hidden" asp-for="OriginalFileName" />

    <div class="card card-body mb-3">
        <div class="d-flex justify-content-between mb-2">
            <strong>Файл: @Model.OriginalFileName</strong>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearRows()">Очистить форму</button>
        </div>

        <table class="table table-sm align-middle">
            <thead><tr><th>Что заменить (OldValue)</th><th>Тип замены</th><th>Новое значение</th><th></th></tr></thead>
            <tbody id="rows">
            @for (var i = 0; i < Model.Replacements.Count; i++)
            {
                <tr>
                    <td><input asp-for="Replacements[i].OldValue" class="form-control" maxlength="500" /></td>
                    <td>
                        <select asp-for="Replacements[i].UseImage" class="form-select" onchange="toggleReplacementType(this)">
                            <option value="false">Текст</option>
                            <option value="true">Изображение</option>
                        </select>
                    </td>
                    <td>
                        <div class="text-replacement" style="display:@(Model.Replacements[i].UseImage ? "none" : "block")">
                            <input asp-for="Replacements[i].NewValue" class="form-control" maxlength="500" />
                        </div>
                        <div class="image-replacement" style="display:@(Model.Replacements[i].UseImage ? "block" : "none")">
                            <input asp-for="Replacements[i].ExistingImagePath" type="hidden" />
                            <input asp-for="Replacements[i].NewImageFile" class="form-control" type="file" accept="image/*" />
                            @if (!string.IsNullOrWhiteSpace(Model.Replacements[i].ExistingImagePath))
                            {
                                <div class="form-text">Текущее изображение уже загружено.</div>
                            }
                        </div>
                    </td>
                    <td><button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('tr').remove()">Удалить</button></td>
                </tr>
            }
            </tbody>
        </table>

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary" onclick="addRow()">Добавить строку</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
            <button class="btn btn-primary">Далее</button>
        </div>
    </div>
</form>

<div class="card card-body">
    <h5>Подсказка</h5>
    <div>Для замены подписи или печати выберите тип <strong>Изображение</strong> и загрузите файл.</div>
    <div>Поле <strong>OldValue</strong> — это текст-якорь, который будет найден в PDF и заменён.</div>
</div>

@section Scripts {
<script>
function clearRows(){
    const tbody=document.getElementById('rows');
    tbody.innerHTML='';
    addRow();
}

function toggleReplacementType(selectElement){
    const row = selectElement.closest('tr');
    const isImage = selectElement.value === 'true';
    row.querySelector('.text-replacement').style.display = isImage ? 'none' : 'block';
    row.querySelector('.image-replacement').style.display = isImage ? 'block' : 'none';
}

function addRow() {
    const tbody = document.getElementById('rows');
    const index = tbody.querySelectorAll('tr').length;
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><input class="form-control" maxlength="500" name="Replacements[${index}].OldValue" /></td>
                    <td>
                        <select class="form-select" name="Replacements[${index}].UseImage" onchange="toggleReplacementType(this)">
                            <option value="false">Текст</option>
                            <option value="true">Изображение</option>
                        </select>
                    </td>
                    <td>
                        <div class="text-replacement">
                            <input class="form-control" maxlength="500" name="Replacements[${index}].NewValue" />
                        </div>
                        <div class="image-replacement" style="display:none">
                            <input type="hidden" name="Replacements[${index}].ExistingImagePath" />
                            <input class="form-control" type="file" accept="image/*" name="Replacements[${index}].NewImageFile" />
                        </div>
                    </td>
                    <td><button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('tr').remove()">Удалить</button></td>`;
    tbody.appendChild(tr);
}
</script>
}
